{
  "version": "1.2.4",
  "name": "Silly Sim Tracker",
  "identifier": "silly_sim_tracker",
  "author": "Prolix OCs",
  "github": "https://github.com/prolix-oc/Lumiverse-SimTracker",
  "homepage": "https://github.com/prolix-oc/Lumiverse-SimTracker",
  "description": "Lumiverse extension for rendering tracker cards using data that the LLM supplies in-message.",
  "permissions": [
    "interceptor",
    "ephemeral_storage",
    "chat_mutation",
    "chats",
    "event_tracking",
    "generation",
    "generation_parameters",
    "app_manipulation"
  ],
  "entry_backend": "dist/backend.js",
  "entry_frontend": "dist/frontend.js",
  "storage_seed_files": [
    {
      "from": "tracker-card-templates",
      "to": "templates",
      "overwrite": false,
      "required": true
    }
  ],
  "minimum_lumiverse_version": "1.0.1"
}
