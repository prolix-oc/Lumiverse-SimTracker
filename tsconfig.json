{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "declaration": false,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"]
  },
  "include": ["src"]
}
